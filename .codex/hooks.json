{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "\"$CODER_STUDIO_APP_BIN\" --coder-studio-agent-hook",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "\"$CODER_STUDIO_APP_BIN\" --coder-studio-agent-hook",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "\"$CODER_STUDIO_APP_BIN\" --coder-studio-agent-hook",
            "type": "command"
          }
        ],
        "matcher": "startup|resume"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "\"$CODER_STUDIO_APP_BIN\" --coder-studio-agent-hook",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "\"$CODER_STUDIO_APP_BIN\" --coder-studio-agent-hook",
            "type": "command"
          }
        ]
      }
    ]
  }
}