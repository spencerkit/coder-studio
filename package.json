{
  "name": "coder-studio-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:stack": "node scripts/test/start-dev-stack.mjs",
    "dev:frontend": "vite",
    "dev:backend": "cargo run --manifest-path src-tauri/Cargo.toml",
    "build": "pnpm build:web",
    "build:web": "vite build",
    "build:runtime": "cargo build --release --manifest-path src-tauri/Cargo.toml",
    "build:packages": "node scripts/build/build-packages.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "test:e2e": "playwright test",
    "test:e2e:release": "playwright test -c playwright.release.config.ts",
    "test:cli": "node --test tests/cli/config.test.mjs tests/cli/platform.test.mjs",
    "test:smoke": "node --test tests/smoke/cli-smoke.test.mjs",
    "pack:local": "node scripts/release/pack-local.mjs",
    "release:check": "pnpm build:web && pnpm build:runtime && pnpm build:packages",
    "version:sync": "node scripts/release/sync-version.mjs",
    "changeset": "changeset",
    "changeset:version": "pnpm changeset version && pnpm version:sync",
    "release:publish": "changeset publish"
  },
  "dependencies": {
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@monaco-editor/react": "^4.7.0",
    "@relax-state/react": "^0.0.10",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "playwright": "^1.47.0",
    "sharp": "^0.34.5",
    "typescript": "^5.5.4",
    "vite": "^8.0.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
